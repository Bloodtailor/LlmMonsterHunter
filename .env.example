# Monster Hunter Game Environment Variables

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=monster_hunter_game
# Offline test suites use their own database so a crashed run never
# leaves debris in real game data (created automatically when missing)
DB_NAME_TEST=monster_hunter_game_test
DB_USER=root
DB_PASSWORD=your_mysql_password_here

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
# Setup replaces this placeholder with a generated value when it creates .env
SECRET_KEY=your-secret-key-here

# LLM Configuration - LOCAL ESCAPE HATCH ONLY (unsupported)
# The API-first game ignores these: text (DeepSeek) and card art (Gemini)
# are configured IN-GAME via the gear icon -> Settings, keys and all.
# The supported floor is a 1M-token context window (docs/plans/cloud-generation.md).
# Local GGUF models below that remain a use-at-your-own-risk escape hatch:
# set LLM_CONTEXT_SIZE to your model's real window if you go that route.
LLM_MODEL_PATH=models/your-model.gguf
LLM_CONTEXT_SIZE=1000000
LLM_GPU_LAYERS=35

# Python Root
PYTHONPATH=.

# Image generation (Gemini "Nano Banana") is configured IN-GAME:
# Settings (gear icon) -> Images. The API key lives in the game_settings
# database row, not here.